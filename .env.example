# Optional manual/deployment configuration.
# The dashboard is the main setup path. These values seed data/settings.json
# on first run when that file does not exist yet.
DNBOT_Discord__Token=your_bot_token_here
DNBOT_Discord__Prefix=!
DNBOT_Discord__DevelopmentGuildId=123456789012345678

# Optional: change the local dashboard bind URL.
Dashboard__Url=http://localhost:5080
